# Session encryption secret (min 32 characters)
NUXT_SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# OIDC Provider (siwe-oidc server)
NUXT_OIDC_ISSUER=http://localhost:3000
NUXT_OIDC_CLIENT_ID=
NUXT_OIDC_CLIENT_SECRET=
NUXT_OIDC_REDIRECT_URI=http://localhost:3001/api/auth/callback
NUXT_OIDC_SCOPE=openid profile
